# Diamond Profile — Vercel Production environment
# Add every variable below to the Production environment only.
# Values beginning with REPLACE_WITH_ are private/account-specific and must
# be entered in Vercel. Never commit their real values to this file.

# Supabase (linked production project: fyhfikfhusuaepsvzcui)
NEXT_PUBLIC_SUPABASE_URL=https://fyhfikfhusuaepsvzcui.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# Comma-separated emails allowed to view the read-only /admin dashboard
ADMIN_EMAILS=REPLACE_WITH_ADMIN_EMAIL_ADDRESS

# Public application URLs
NEXT_PUBLIC_APP_DOMAIN=diamondprofile.app,www.diamondprofile.app
NEXT_PUBLIC_APP_URL=https://diamondprofile.app

# Stripe live mode — the price IDs below are the existing live catalog
STRIPE_MODE=live
STRIPE_SECRET_KEY=REPLACE_WITH_SK_LIVE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_LIVE_WEBHOOK_SIGNING_SECRET
STRIPE_PRO_PRICE_ID=price_1TwAwFL5oLjtdDUPu44P4txm
STRIPE_ELITE_PRICE_ID=price_1TwAwWL5oLjtdDUP7uomhz9f
STRIPE_CUSTOM_DOMAIN_PRICE_ID=price_1TwAwwL5oLjtdDUPBZlLZqap

# Vercel managed-domain fulfillment
VERCEL_API_TOKEN=REPLACE_WITH_VERCEL_API_TOKEN
VERCEL_TEAM_ID=REPLACE_WITH_VERCEL_TEAM_ID
VERCEL_PROJECT_ID_OR_NAME=baseball-portfolio
CRON_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_16_CHARACTERS
DOMAIN_MAX_PURCHASE_PRICE_USD=25

# Registrant for domains purchased and owned by Diamond Profile
DOMAIN_REGISTRANT_FIRST_NAME=REPLACE_WITH_FIRST_NAME
DOMAIN_REGISTRANT_LAST_NAME=REPLACE_WITH_LAST_NAME
DOMAIN_REGISTRANT_EMAIL=REPLACE_WITH_EMAIL
DOMAIN_REGISTRANT_PHONE=REPLACE_WITH_E164_PHONE_NUMBER
DOMAIN_REGISTRANT_ADDRESS1=REPLACE_WITH_STREET_ADDRESS
DOMAIN_REGISTRANT_ADDRESS2=
DOMAIN_REGISTRANT_CITY=REPLACE_WITH_CITY
DOMAIN_REGISTRANT_STATE=REPLACE_WITH_STATE_CODE
DOMAIN_REGISTRANT_ZIP=REPLACE_WITH_POSTAL_CODE
DOMAIN_REGISTRANT_COUNTRY=US
DOMAIN_REGISTRANT_COMPANY=Diamond Profile

# Professional in-app video hosting
MUX_TOKEN_ID=REPLACE_WITH_PRODUCTION_MUX_TOKEN_ID
MUX_TOKEN_SECRET=REPLACE_WITH_PRODUCTION_MUX_TOKEN_SECRET
